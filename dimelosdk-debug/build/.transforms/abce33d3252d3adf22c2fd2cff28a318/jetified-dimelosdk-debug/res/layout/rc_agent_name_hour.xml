<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/transparent"
    android:orientation="vertical">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/agent_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/rc_agent_name_top_margin"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/dimelo_agent_name_left_padding"
            android:paddingLeft="@dimen/dimelo_agent_name_left_padding"
            android:paddingTop="@dimen/dimelo_agent_name_top_padding"
            android:paddingEnd="@dimen/dimelo_agent_name_right_padding"
            android:paddingRight="@dimen/dimelo_agent_name_right_padding"
            android:paddingBottom="@dimen/dimelo_agent_name_bottom_padding"
            android:textColor="@color/dimelo_agent_name_color"
            android:textSize="@dimen/dimelo_agent_name_text_size" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/hour_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/rc_agent_name_hour_spacing"
            android:layout_marginLeft="@dimen/rc_agent_name_hour_spacing"
            android:layout_marginTop="@dimen/rc_agent_name_top_margin"
            android:layout_marginEnd="@dimen/rc_agent_name_hour_spacing"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/dimelo_agent_name_left_padding"
            android:paddingLeft="@dimen/dimelo_agent_name_left_padding"
            android:paddingTop="@dimen/dimelo_agent_name_top_padding"
            android:paddingEnd="@dimen/dimelo_agent_name_right_padding"
            android:paddingRight="@dimen/dimelo_agent_name_right_padding"
            android:paddingBottom="@dimen/dimelo_agent_name_bottom_padding"
            android:textColor="@color/dimelo_agent_name_color"
            android:textSize="@dimen/dimelo_agent_name_text_size" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <RelativeLayout
        android:id="@+id/thumbs_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/rc_list_row_horizontal_padding_left"
        android:layout_marginBottom="@dimen/rc_list_row_horizontal_padding_left">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/thumbs_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rc_thumbs_background_button"
            android:src="@drawable/rc_thumbs_up"
            android:visibility="gone"
             />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/thumbs_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/rc_list_row_horizontal_padding_left"
            android:layout_toEndOf="@+id/thumbs_up"
            android:background="@drawable/rc_thumbs_background_button"
            android:src="@drawable/rc_thumbs_down"
            android:visibility="gone"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/tell_us_more"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/rc_list_row_horizontal_padding_left"
            android:layout_toEndOf="@+id/thumbs_down"
            android:background="@drawable/rc_tell_us_more_background_button"
            android:gravity="center_vertical"
            android:text="@string/rc_tell_us_More"
            android:textAllCaps="false"
            android:textColor="#4481EB"
            android:textSize="16sp"
            android:visibility="gone" />

    </RelativeLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
