<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/DimeloRowTheme"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical">

    <include
        layout="@layout/dimelo_date_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="@dimen/rc_list_row_horizontal_padding_left"
        android:layout_marginRight="@dimen/dimelo_list_row_horizontal_padding" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/horizontal_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingLeft="@dimen/rc_list_row_horizontal_padding_left" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/avatar_agent_name_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/rc_list_row_horizontal_padding_left"
        android:layout_marginTop="@dimen/rc_avatar_carousel_vertical_spacing"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/avatar_img_container"
            android:layout_width="@dimen/rc_avatar_image_size"
            android:layout_height="@dimen/rc_avatar_image_size"
            android:layout_gravity="start|center_vertical"
            android:layout_marginRight="@dimen/rc_list_row_horizontal_padding_left"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/avatar_img"
                android:layout_width="@dimen/rc_avatar_image_size"
                android:layout_height="@dimen/rc_avatar_image_size" />
        </androidx.cardview.widget.CardView>


        <include
            layout="@layout/rc_agent_name_hour_carousel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical" />
    </androidx.appcompat.widget.LinearLayoutCompat>
    <RelativeLayout
        android:id="@+id/thumbs_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/rc_list_row_horizontal_padding_left"
        android:layout_marginBottom="@dimen/rc_list_row_horizontal_padding_left">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/thumbs_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rc_thumbs_background_button"
            android:src="@drawable/rc_thumbs_up"
            android:visibility="gone"
            />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/thumbs_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/rc_list_row_horizontal_padding_left"
            android:layout_toEndOf="@+id/thumbs_up"
            android:background="@drawable/rc_thumbs_background_button"
            android:src="@drawable/rc_thumbs_down"
            android:visibility="gone"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/tell_us_more"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/rc_list_row_horizontal_padding_left"
            android:layout_toEndOf="@+id/thumbs_down"
            android:background="@drawable/rc_tell_us_more_background_button"
            android:gravity="center_vertical"
            android:text="@string/rc_tell_us_More"
            android:textAllCaps="false"
            android:textColor="#4481EB"
            android:textSize="16sp"
            android:visibility="gone" />

    </RelativeLayout>

</androidx.appcompat.widget.LinearLayoutCompat>
